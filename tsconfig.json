{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@matex/types": ["packages/shared/types/src"],
      "@matex/utils": ["packages/shared/utils/src"],
      "@matex/logic": ["packages/shared/logic/src"]
    }
  },
  "include": [
    "apps/mcp-gateway/**/*.ts",
    "packages/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", ".next"]
}
