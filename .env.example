# ============================================================================
# MATEX - Environment Variables
# Copy this file to .env.local and fill in the values
# ============================================================================

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_DB_URL=postgresql://postgres:password@db.YOUR_PROJECT.supabase.co:5432/postgres

# ---- Redis (Upstash) ----
UPSTASH_REDIS_REST_URL=https://YOUR_REDIS.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token

# ---- Stripe ----
# Set these to enable real payment processing. The bridge auto-switches from stub to live mode.
# Get test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# ---- SendGrid ----
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=noreply@matex.ca
SENDGRID_FROM_NAME=Matex

# ---- Twilio ----
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1...

# ---- Google Maps ----
GOOGLE_MAPS_API_KEY=AIza...

# ---- DocuSign ----
DOCUSIGN_INTEGRATION_KEY=your_integration_key
DOCUSIGN_SECRET_KEY=your_secret
DOCUSIGN_ACCOUNT_ID=your_account_id
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi

# ---- Onfido (KYC) ----
ONFIDO_API_TOKEN=api_sandbox_...

# ---- JWT ----
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3001
NODE_ENV=development
LOG_LEVEL=debug

# ---- Local DB / UI Harness ----
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres
UI_RESET_SECRET=

# ---- Gateway domain forwarding (production-like) ----
# Map each MCP domain to its HTTP adapter endpoint.
MCP_DOMAIN_ENDPOINTS_JSON={"auth":"http://localhost:4101/tool","profile":"http://localhost:4102/tool","listing":"http://localhost:4103/tool","search":"http://localhost:4104/tool","messaging":"http://localhost:4105/tool","payments":"http://localhost:4106/tool","kyc":"http://localhost:4107/tool","escrow":"http://localhost:4108/tool","bidding":"http://localhost:4109/tool","auction":"http://localhost:4110/tool","inspection":"http://localhost:4111/tool","booking":"http://localhost:4112/tool","logistics":"http://localhost:4113/tool","contracts":"http://localhost:4114/tool","dispute":"http://localhost:4115/tool","tax":"http://localhost:4116/tool","notifications":"http://localhost:4117/tool","analytics":"http://localhost:4118/tool","pricing":"http://localhost:4119/tool","credit":"http://localhost:4120/tool","admin":"http://localhost:4121/tool","esign":"http://localhost:4122/tool"}

# ---- Sentry ----
SENTRY_DSN=https://xxx@sentry.io/xxx
