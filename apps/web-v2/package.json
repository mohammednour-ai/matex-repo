{
  "name": "@matex/web-v2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "cross-env NODE_ENV=production next build",
    "start": "cross-env NODE_ENV=production next start",
    "lint": "next lint",
    "test:e2e": "playwright test",
    "test:e2e:ci": "pnpm run build && playwright test",
    "test:smoke": "playwright test --project=smoke",
    "test:api": "playwright test --project=api",
    "test:functional": "playwright test --project=functional",
    "test:regression": "playwright test --project=regression",
    "test:uiux": "playwright test --project=uiux",
    "test:visual": "playwright test --project=visual",
    "test:visual:update": "playwright test --project=visual --update-snapshots",
    "test:compliance": "playwright test --project=compliance",
    "test:legacy": "playwright test --project=legacy",
    "test:report": "tsx e2e/report/generate-report.ts",
    "test:dev-prompts": "tsx e2e/report/generate-dev-prompts.ts"
  },
  "dependencies": {
    "@matex/utils": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/nextjs": "^10.51.0",
    "@tanstack/react-table": "^8.21.3",
    "@tremor/react": "^3.18.7",
    "autoprefixer": "^10.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "inngest": "^4.2.6",
    "lucide-react": "^0.400.0",
    "next": "^14.1.0",
    "next-intl": "^4.11.0",
    "pg": "^8.13.1",
    "postcss": "^8.4.0",
    "posthog-js": "^1.372.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "sonner": "^1.7.4",
    "stripe": "^17.4.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "cross-env": "^10.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
