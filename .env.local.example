# ============================================================================
# MATEX - Local development baseline
# Copy to .env.local and adjust.
# ============================================================================

# Core runtime (required)
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres
JWT_SECRET=replace_with_min_32_char_secret_for_local

# Web <-> gateway
NEXT_PUBLIC_APP_URL=http://localhost:3002
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3001
MCP_GATEWAY_URL=http://localhost:3001

# Gateway forwarding to local HTTP adapters
MCP_DOMAIN_ENDPOINTS_JSON={"auth":"http://localhost:4101/tool","profile":"http://localhost:4102/tool","listing":"http://localhost:4103/tool","search":"http://localhost:4104/tool","messaging":"http://localhost:4105/tool","payments":"http://localhost:4106/tool","kyc":"http://localhost:4107/tool","escrow":"http://localhost:4108/tool","bidding":"http://localhost:4109/tool","auction":"http://localhost:4110/tool","inspection":"http://localhost:4111/tool","booking":"http://localhost:4112/tool","logistics":"http://localhost:4113/tool","contracts":"http://localhost:4114/tool","dispute":"http://localhost:4115/tool","tax":"http://localhost:4116/tool","notifications":"http://localhost:4117/tool","analytics":"http://localhost:4118/tool","pricing":"http://localhost:4119/tool","credit":"http://localhost:4120/tool","admin":"http://localhost:4121/tool","esign":"http://localhost:4122/tool"}

# Optional local persistence for gateway dev login
MATEX_DEV_SEED_EMAIL=you@example.com
MATEX_DEV_SEED_PASSWORD=change_me_for_local
MATEX_DEV_SEED_PHONE=+10000000000
MATEX_DEV_SEED_ACCOUNT_TYPE=both
MATEX_DEV_ADMIN_EMAILS=you@example.com

# Optional integrations (leave blank for stub mode)
REDIS_URL=
STRIPE_SECRET_KEY=
SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional utilities
UI_RESET_SECRET=
NODE_ENV=development
LOG_LEVEL=debug
